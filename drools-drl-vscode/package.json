{
  "name": "drools-drl",
  "displayName": "Drools DRL",
  "description": "Language support for Drools Rule Language (.drl) files",
  "version": "0.1.0",
  "publisher": "tbd",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "drools",
    "drl",
    "rule engine",
    "business rules",
    "kie"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "contributes": {
    "languages": [
      {
        "id": "drools",
        "aliases": [
          "Drools",
          "DRL",
          "Drools Rule Language"
        ],
        "extensions": [
          ".drl",
          ".rule"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/drl-icon.png",
          "dark": "./icons/drl-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "drools",
        "scopeName": "source.drools",
        "path": "./syntaxes/drl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "drools",
        "path": "./snippets/drl.snippets.json"
      }
    ]
  }
}
