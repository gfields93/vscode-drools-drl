{
  "name": "drools-drl",
  "displayName": "Drools DRL",
  "description": "Language support for Drools Rule Language (.drl) files",
  "version": "0.2.0",
  "publisher": "tbd",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "drools",
    "drl",
    "rule engine",
    "business rules",
    "kie"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "main": "./out/client/src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "drools",
        "aliases": [
          "Drools",
          "DRL",
          "Drools Rule Language"
        ],
        "extensions": [
          ".drl",
          ".rule"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/drl-icon.png",
          "dark": "./icons/drl-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "drools",
        "scopeName": "source.drools",
        "path": "./syntaxes/drl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "drools",
        "path": "./snippets/drl.snippets.json"
      }
    ],
    "configuration": {
      "title": "Drools DRL",
      "properties": {
        "drools.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces communication between VS Code and the Drools language server"
        },
        "drools.validation.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable real-time DRL validation"
        },
        "drools.validation.debounceMs": {
          "type": "number",
          "default": 200,
          "description": "Delay in ms before re-validating after a document change"
        },
        "drools.completion.showDeprecated": {
          "type": "boolean",
          "default": true,
          "description": "Show deprecated DRL constructs in completion suggestions"
        },
        "drools.formatting.indentSize": {
          "type": "number",
          "default": 4,
          "description": "Number of spaces per indentation level"
        },
        "drools.formatting.insertFinalNewline": {
          "type": "boolean",
          "default": true,
          "description": "Ensure file ends with a newline"
        },
        "drools.java.classpath": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "maven", "gradle", "manual"],
          "description": "How to resolve the Java classpath. 'auto' detects from project files."
        },
        "drools.java.manualClasspath": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Manual classpath entries (JAR paths or directories) when classpath mode is 'manual'"
        },
        "drools.java.sourceRoots": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["src/main/java"],
          "description": "Java source roots to scan for type definitions"
        },
        "drools.java.useJavapFallback": {
          "type": "boolean",
          "default": false,
          "description": "Fall back to 'javap' for class file parsing when the built-in parser encounters unsupported class file features. Requires a JDK installation."
        },
        "drools.analysis.conflictDetection": {
          "type": "boolean",
          "default": true,
          "description": "Enable rule conflict and redundancy analysis"
        },
        "drools.analysis.maxRulesForConflictAnalysis": {
          "type": "number",
          "default": 500,
          "description": "Maximum number of rules to include in conflict analysis (higher values are slower)"
        },
        "drools.index.excludePatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["**/test/**", "**/target/**", "**/build/**"],
          "description": "Glob patterns for files/directories to exclude from indexing"
        }
      }
    },
    "commands": [
      {
        "command": "drools.rebuildWorkspaceIndex",
        "title": "Drools: Rebuild Workspace Index"
      },
      {
        "command": "drools.rebuildClasspath",
        "title": "Drools: Rebuild Classpath"
      },
      {
        "command": "drools.showTypeInfo",
        "title": "Drools: Show Type Info"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "lint": "eslint .",
    "test": "vitest run",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "chevrotain": "^11.0.3",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.3.3",
    "vitest": "^3.1.1"
  }
}
