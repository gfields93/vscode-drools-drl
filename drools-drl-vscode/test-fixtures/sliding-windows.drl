// Test: Sliding window declarations (CEP)
package com.example.rules;

import com.example.model.*;

// Time-based sliding window
rule "Recent Events"
    when
        $e : SensorEvent( type == "TEMPERATURE" ) over window:time( 5m )
    then
        System.out.println("Recent temperature reading: " + $e.getValue());
end

// Length-based sliding window
rule "Last N Events"
    when
        $e : SensorEvent( type == "PRESSURE" ) over window:length( 100 )
    then
        System.out.println("Pressure in last 100: " + $e.getValue());
end

// Sliding window with accumulate
rule "Average Temperature"
    when
        $avg : Number() from accumulate(
            SensorEvent( type == "TEMPERATURE" ) over window:time( 1h ),
            average( $e.getValue() )
        )
    then
        System.out.println("Avg temperature (1h): " + $avg);
end

// Sliding window with binding
rule "Window With Binding"
    when
        $e : SensorEvent( value > 100.0 ) over window:time( 30s )
    then
        System.out.println("High value in last 30s: " + $e.getValue());
end

// Multiple windows in one rule
rule "Multi Window"
    when
        $temp : SensorEvent( type == "TEMPERATURE", value > 50 ) over window:time( 10m )
        $pressure : SensorEvent( type == "PRESSURE", value > 1013 ) over window:time( 10m )
    then
        System.out.println("High temp and pressure detected");
end
